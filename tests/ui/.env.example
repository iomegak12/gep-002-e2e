# Web app URL (matches root docker-compose.yml: gep-web on 8080)
WEB_URL=http://localhost:8080

# Default login credentials (seeded admin)
USER_EMAIL=admin@demo.local
USER_PASSWORD=Passw0rd!

# Inter-step pacing (milliseconds) -- explicit pauses between logical steps
STEP_DELAY_MIN_MS=300
STEP_DELAY_MAX_MS=300

# Per-action slowdown applied by Playwright itself (ms).
# Affects every click / fill / goto / wait, so the run is easy to follow.
STEP_SLOWMO_MS=300
