# URLs of the three services (defaults match docker-compose host ports)
IAM_URL=http://localhost:3001
SUPPLIER_URL=http://localhost:3002
PO_URL=http://localhost:3003

# How long the global setup waits for /health on each service (ms)
WAIT_FOR_STACK_TIMEOUT=60000

# Seeded credentials (must match what back-end/seed/run.js creates)
ADMIN_EMAIL=admin@demo.local
BUYER_EMAIL=buyer@demo.local
APPROVER_HI_EMAIL=approver-hi@demo.local
APPROVER_LO_EMAIL=approver-lo@demo.local
SEED_PASSWORD=Passw0rd!

# Auto-approval threshold configured on po-service (must match its env)
PO_APPROVAL_THRESHOLD=100000
