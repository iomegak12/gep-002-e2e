# Shared across all services
JWT_SECRET=dev-only-change-me-please-32chars-min-secret
JWT_ISSUER=gep-auth
ACCESS_TOKEN_TTL_SECONDS=86400

# Postgres (shared instance, two logical DBs)
POSTGRES_USER=gep
POSTGRES_PASSWORD=gep
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
AUTH_DATABASE_URL=postgresql://gep:gep@postgres:5432/auth
PO_DATABASE_URL=postgresql://gep:gep@postgres:5432/po

# Mongo
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB=suppliers

# Service URLs (inside compose network)
AUTH_SERVICE_URL=http://iam:3001/api/v1
SUPPLIER_SERVICE_URL=http://supplier-service:3002/api/v1
PO_SERVICE_URL=http://po-service:3003/api/v1

# PO Service tuning
DEFAULT_APPROVAL_THRESHOLD=100000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
