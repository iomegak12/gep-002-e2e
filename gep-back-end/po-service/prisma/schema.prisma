generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PurchaseOrder {
  id                     String       @id @default(uuid()) @db.Uuid
  po_number              String       @unique @db.VarChar(20)
  supplier_id            String       @db.Uuid
  supplier_snapshot      Json?
  buyer_id               String       @db.Uuid
  approver_id            String?      @db.Uuid
  status                 String       @db.VarChar(20)
  currency               String       @db.Char(3)
  subtotal               Decimal      @db.Decimal(15, 2)
  tax_amount             Decimal      @default(0) @db.Decimal(15, 2)
  total_amount           Decimal      @db.Decimal(15, 2)
  expected_delivery_date DateTime?    @db.Date
  actual_delivery_date   DateTime?    @db.Date
  delivery_address       Json?
  payment_terms          String       @db.VarChar(20)
  notes                  String?
  rejection_reason       String?
  requires_approval      Boolean
  approval_threshold     Decimal      @db.Decimal(15, 2)
  created_at             DateTime     @default(now()) @db.Timestamptz()
  submitted_at           DateTime?    @db.Timestamptz()
  approved_at            DateTime?    @db.Timestamptz()
  fulfilled_at           DateTime?    @db.Timestamptz()
  closed_at              DateTime?    @db.Timestamptz()
  updated_at             DateTime     @default(now()) @updatedAt @db.Timestamptz()

  line_items POLineItem[]

  @@index([status])
  @@index([supplier_id])
  @@index([buyer_id])
  @@index([created_at])
  @@map("purchase_orders")
}

model POLineItem {
  id               String   @id @default(uuid()) @db.Uuid
  po_id            String   @db.Uuid
  line_number      Int
  item_description String   @db.VarChar(500)
  sku              String?  @db.VarChar(50)
  quantity         Decimal  @db.Decimal(12, 3)
  unit_of_measure  String   @db.VarChar(10)
  unit_price       Decimal  @db.Decimal(15, 4)
  tax_rate         Decimal  @default(0) @db.Decimal(5, 2)
  line_total       Decimal  @db.Decimal(15, 2)
  notes            String?

  po PurchaseOrder @relation(fields: [po_id], references: [id], onDelete: Cascade)

  @@unique([po_id, line_number])
  @@map("po_line_items")
}

model PoNumberSeq {
  year       Int @id
  last_value Int @default(0)

  @@map("po_number_seq")
}
