{
  "uid": "gep-node-overview",
  "title": "GEP — Node.js Service Overview (iam, po-service)",
  "tags": ["gep", "node"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {"name": "service", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(process_cpu_utilization, service_name)", "refresh": 2, "includeAll": true, "multi": true, "current": {"text": "All", "value": "$__all"}}
    ]
  },
  "panels": [
    {"type": "timeseries", "title": "Process CPU %", "gridPos": {"x": 0, "y": 0, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percentunit"}}, "targets": [{"expr": "process_cpu_utilization{service_name=~\"$service\"}", "legendFormat": "{{service_name}}"}]},
    {"type": "timeseries", "title": "Process RSS memory", "gridPos": {"x": 12, "y": 0, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"expr": "process_memory_usage{service_name=~\"$service\"}", "legendFormat": "{{service_name}}"}]},
    {"type": "timeseries", "title": "Event loop delay (p95)", "gridPos": {"x": 0, "y": 7, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(nodejs_eventloop_delay_seconds_bucket{service_name=~\"$service\"}[5m])))", "legendFormat": "{{service_name}}"}]},
    {"type": "timeseries", "title": "Heap used / total", "gridPos": {"x": 12, "y": 7, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"expr": "v8js_heap_size_used_bytes{service_name=~\"$service\"}", "legendFormat": "{{service_name}} used"}, {"expr": "v8js_heap_size_total_bytes{service_name=~\"$service\"}", "legendFormat": "{{service_name}} total"}]},
    {"type": "timeseries", "title": "HTTP server p95 latency", "gridPos": {"x": 0, "y": 14, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))", "legendFormat": "{{service_name}}"}]},
    {"type": "timeseries", "title": "DB calls / sec (pg + prisma)", "gridPos": {"x": 12, "y": 14, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum by (service_name, db_system) (rate(db_client_operation_duration_seconds_count{service_name=~\"$service\"}[5m]))", "legendFormat": "{{service_name}} - {{db_system}}"}]}
  ]
}
