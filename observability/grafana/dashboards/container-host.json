{
  "uid": "gep-container-host",
  "title": "GEP — Container & Host",
  "tags": ["gep", "infra"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"type": "stat", "title": "Host CPU %", "gridPos": {"x": 0, "y": 0, "w": 6, "h": 5}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent"}}, "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)"}]},
    {"type": "stat", "title": "Host Mem used %", "gridPos": {"x": 6, "y": 0, "w": 6, "h": 5}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent"}}, "targets": [{"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))"}]},
    {"type": "stat", "title": "Disk used %", "gridPos": {"x": 12, "y": 0, "w": 6, "h": 5}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent"}}, "targets": [{"expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}))"}]},
    {"type": "stat", "title": "Containers running", "gridPos": {"x": 18, "y": 0, "w": 6, "h": 5}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "count(container_last_seen{name!=\"\"})"}]},
    {"type": "timeseries", "title": "Per-container CPU", "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percentunit"}}, "targets": [{"expr": "rate(container_cpu_usage_seconds_total{name=~\"gep-.*\"}[1m])", "legendFormat": "{{name}}"}]},
    {"type": "timeseries", "title": "Per-container Memory", "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"expr": "container_memory_usage_bytes{name=~\"gep-.*\"}", "legendFormat": "{{name}}"}]},
    {"type": "timeseries", "title": "Per-container Network RX", "gridPos": {"x": 0, "y": 13, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "Bps"}}, "targets": [{"expr": "rate(container_network_receive_bytes_total{name=~\"gep-.*\"}[1m])", "legendFormat": "{{name}}"}]},
    {"type": "timeseries", "title": "Per-container Disk IO", "gridPos": {"x": 12, "y": 13, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "Bps"}}, "targets": [{"expr": "rate(container_fs_reads_bytes_total{name=~\"gep-.*\"}[1m])", "legendFormat": "read {{name}}"}, {"expr": "rate(container_fs_writes_bytes_total{name=~\"gep-.*\"}[1m])", "legendFormat": "write {{name}}"}]}
  ]
}
